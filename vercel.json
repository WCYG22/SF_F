{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "typescript": {
    "version": "5.8.3"
  },
  "functions": {
    "api/search.js": {
      "memory": 1024,
      "maxDuration": 30
    },
    "api/tracking.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/search",
      "destination": "/api/search.js"
    },
    {
      "source": "/api/tracking",
      "destination": "/api/tracking.js"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
